# Handoff environment variables.
#
# Copy this file to .env and fill in your Supabase project's values:
#   cp .env.example .env
#
# NEVER commit .env or real keys. .env is gitignored; only the anon (public)
# key belongs in a browser build — never the service-role key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
